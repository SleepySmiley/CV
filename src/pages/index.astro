---
import "../styles/global.css";
import CursorLight from "../components/CursorLight.astro";

const contacts = [
	{
		label: "Email",
		value: "christianmattiolo@gmail.com",
		href: "mailto:christianmattiolo@gmail.com",
	},
	{
		label: "Telefono",
		value: "+39 392 365 1045",
		href: "tel:+393923651045",
	},
	{
		label: "GitHub",
		value: "SleepySmiley",
		href: "https://github.com/SleepySmiley",
	},
	{
		label: "Base",
		value: "Mercato Saraceno, IT",
		href: "https://maps.google.com/?q=Mercato-Saraceno,Italy",
	},
];

const heroPhoto = "/photo-placeholder.jpg";

const navigation = [
	{ href: "/", label: "Home", current: true },
	{ href: "/programming", label: "Programming" },
	{ href: "/beatmaking", label: "Beatmaking" },
	{ href: "/photography", label: "Photography" },
	{ href: "/me", label: "Me" },
];
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Homepage portfolio in stile hero cinematografico con accesso rapido alle principali sezioni del CV."
		/>
		<title>Christian Mattiolo | Creative CV</title>
	</head>
	<body class="min-h-screen bg-[#121118] text-stone-100">
		<main class="relative isolate min-h-screen overflow-hidden">
			<div class="absolute inset-0 -z-30 bg-[linear-gradient(120deg,#121118_0%,#17151d_28%,#2d2523_56%,#17131b_100%)]"></div>
			<div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_67%_32%,rgba(255,140,56,0.90),rgba(255,140,56,0.28)_18%,rgba(255,140,56,0.0)_40%),radial-gradient(circle_at_86%_28%,rgba(255,243,224,0.42),rgba(255,243,224,0.0)_28%),radial-gradient(circle_at_26%_58%,rgba(255,255,255,0.12),rgba(255,255,255,0.0)_34%)]"></div>
			<div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(6,6,9,0.95)_0%,rgba(8,8,12,0.82)_28%,rgba(8,8,12,0.34)_56%,rgba(8,8,12,0.08)_78%,rgba(8,8,12,0.0)_100%)]"></div>
			<div class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.028)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.028)_1px,transparent_1px)] bg-size-[82px_82px] opacity-25"></div>
			<CursorLight />

			<div class="relative z-10 flex min-h-screen w-full flex-col px-6 py-6 sm:px-10 sm:py-8 lg:px-14 lg:py-10 xl:px-20">
				<header class="flex items-center justify-start gap-4">
					<div
						class="inline-flex items-center gap-3 text-sm font-medium text-white/90"
						style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
					>
						<span class="h-2.5 w-2.5 rounded-full bg-lime-400 shadow-[0_0_18px_rgba(132,255,79,0.95)]"></span>
						<span>Open to work</span>
					</div>
				</header>

				<section class="flex flex-1 items-center py-10 sm:py-12 lg:py-8">
					<div class="grid w-full gap-6 lg:grid-cols-[minmax(0,1.06fr)_minmax(320px,0.78fr)] xl:grid-cols-[minmax(0,1.12fr)_minmax(360px,0.74fr)]">
						<div class="relative z-20 max-w-3xl">
							<p
								class="text-sm font-semibold uppercase tracking-[0.18em] text-amber-300 sm:text-base"
								style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
							>
								UX/UI Designer
							</p>
							<h1
								class="mt-5 text-5xl font-bold leading-[0.95] tracking-tight text-white sm:text-6xl lg:text-7xl xl:text-[5.5rem]"
								style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
							>
								Christian
								<span class="block">Mattiolo</span>
							</h1>

							<div class="mt-12 grid gap-5 sm:grid-cols-2">
								{
									contacts.map((contact) => (
										<a
											href={contact.href}
											class="group flex items-center gap-4 text-white transition duration-300 hover:translate-x-1"
											target={contact.href.startsWith("http") ? "_blank" : undefined}
											rel={contact.href.startsWith("http") ? "noreferrer" : undefined}
										>
											<span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-amber-300/25 bg-amber-300/8 text-amber-300 transition duration-300 group-hover:border-amber-200/50 group-hover:bg-amber-200/12">
												{
													contact.label === "Email" && (
														<svg
															viewBox="0 0 24 24"
															aria-hidden="true"
															class="h-5 w-5 fill-none stroke-current"
															stroke-width="1.8"
															stroke-linecap="round"
															stroke-linejoin="round"
														>
															<path d="M3 6.75h18v10.5H3z"></path>
															<path d="m4.5 8.25 7.5 6 7.5-6"></path>
														</svg>
													)
												}
												{
													contact.label === "Telefono" && (
														<svg
															viewBox="0 0 24 24"
															aria-hidden="true"
															class="h-5 w-5 fill-none stroke-current"
															stroke-width="1.8"
															stroke-linecap="round"
															stroke-linejoin="round"
														>
															<path d="M6.6 3.75h3.15L11.25 8l-1.95 1.95a18.2 18.2 0 0 0 4.75 4.75L16 12.75l4.25 1.5v3.15A2.1 2.1 0 0 1 18.15 19.5c-7.12 0-12.9-5.78-12.9-12.9A2.1 2.1 0 0 1 6.6 3.75Z"></path>
														</svg>
													)
												}
												{
													contact.label === "GitHub" && (
														<svg
															viewBox="0 0 24 24"
															aria-hidden="true"
															class="h-5 w-5 fill-current"
														>
															<path d="M12 .75A11.25 11.25 0 0 0 .75 12a11.25 11.25 0 0 0 7.69 10.67c.56.1.76-.24.76-.54v-1.9c-3.13.68-3.8-1.33-3.8-1.33-.5-1.28-1.24-1.62-1.24-1.62-1.01-.69.08-.68.08-.68 1.12.08 1.7 1.14 1.7 1.14.99 1.7 2.6 1.2 3.24.92.1-.72.39-1.2.7-1.48-2.5-.28-5.13-1.25-5.13-5.57 0-1.23.44-2.24 1.15-3.03-.12-.28-.5-1.42.11-2.96 0 0 .94-.3 3.08 1.16a10.68 10.68 0 0 1 5.61 0c2.14-1.46 3.08-1.16 3.08-1.16.61 1.54.23 2.68.11 2.96.72.79 1.15 1.8 1.15 3.03 0 4.33-2.63 5.28-5.14 5.56.4.35.76 1.04.76 2.1v3.11c0 .3.2.65.77.54A11.25 11.25 0 0 0 23.25 12 11.25 11.25 0 0 0 12 .75Z"></path>
														</svg>
													)
												}
												{
													contact.label === "Base" && (
														<svg
															viewBox="0 0 24 24"
															aria-hidden="true"
															class="h-5 w-5 fill-none stroke-current"
															stroke-width="1.8"
															stroke-linecap="round"
															stroke-linejoin="round"
														>
															<path d="M12 20.25s6-5.46 6-10.5a6 6 0 1 0-12 0c0 5.04 6 10.5 6 10.5Z"></path>
															<circle cx="12" cy="9.75" r="2.25"></circle>
														</svg>
													)
												}
											</span>

											<span>
												<span
													class="block text-[0.7rem] uppercase tracking-[0.22em] text-stone-500"
													style="font-family: 'IBM Plex Mono', monospace;"
												>
													{contact.label}
												</span>
												<span
													class="mt-1 block text-base font-medium text-white sm:text-lg"
													style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
												>
													{contact.value}
												</span>
											</span>
										</a>
									))
								}
							</div>
						</div>

						<div class="relative flex min-h-56 items-center justify-center lg:min-h-104 lg:justify-center">
							<figure class="hero-photo-shell">
								<div class="hero-photo-glow"></div>
								<div class="hero-photo-blend"></div>
								<img src={heroPhoto} alt="Foto ritratto di Nome Cognome" class="hero-photo-image" />
							</figure>
						</div>
					</div>
				</section>

				<nav aria-label="Main sections" class="relative z-20 pb-4 sm:pb-6">
					<ul class="mx-auto flex w-full max-w-5xl flex-nowrap items-center justify-start gap-2 overflow-x-auto rounded-4xl border border-white/10 bg-[rgba(75,63,59,0.72)] px-3 py-3 shadow-[0_18px_60px_rgba(0,0,0,0.35)] backdrop-blur-xl sm:justify-center sm:gap-2 sm:overflow-visible sm:px-3 sm:py-4">
						{
							navigation.map((item) => (
								<li class="shrink-0 sm:w-auto sm:flex-1">
									<a
										href={item.href}
										aria-current={item.current ? "page" : undefined}
										class:list={[
											"flex items-center justify-center gap-2 rounded-full px-3 py-2 text-xs font-medium whitespace-nowrap transition duration-300 sm:gap-3 sm:px-4 sm:py-3 sm:text-sm",
											item.current
												? "bg-white text-stone-900 shadow-[0_8px_24px_rgba(255,255,255,0.22)]"
												: "text-white/92 hover:bg-white/10",
										]}
										style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
									>
										<span class={item.current ? "text-stone-700" : "text-white/80"}>
											{
												item.label === "Home" && (
													<svg
														viewBox="0 0 24 24"
														aria-hidden="true"
														class="h-4 w-4 fill-none stroke-current"
														stroke-width="1.8"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<path d="M3.75 10.5 12 4.5l8.25 6"></path>
														<path d="M6 9.75v9h12v-9"></path>
													</svg>
												)
											}
											{
												item.label === "Programming" && (
													<svg
														viewBox="0 0 24 24"
														aria-hidden="true"
														class="h-4 w-4 fill-none stroke-current"
														stroke-width="1.8"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<rect x="4.5" y="5.25" width="15" height="13.5" rx="2"></rect>
														<path d="m9 10.25-2 1.75 2 1.75"></path>
														<path d="m15 10.25 2 1.75-2 1.75"></path>
													</svg>
												)
											}
											{
												item.label === "Beatmaking" && (
													<svg
														viewBox="0 0 24 24"
														aria-hidden="true"
														class="h-4 w-4 fill-none stroke-current"
														stroke-width="1.8"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<path d="M7.5 18V8.25"></path>
														<path d="M12 18V5.25"></path>
														<path d="M16.5 18v-7.5"></path>
													</svg>
												)
											}
											{
												item.label === "Photography" && (
													<svg
														viewBox="0 0 24 24"
														aria-hidden="true"
														class="h-4 w-4 fill-none stroke-current"
														stroke-width="1.8"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<path d="M4.5 8.25h4l1.5-2.25h4l1.5 2.25h4v9.75a2.25 2.25 0 0 1-2.25 2.25h-11A2.25 2.25 0 0 1 4.5 18V8.25Z"></path>
														<circle cx="12" cy="13.5" r="3"></circle>
													</svg>
												)
											}
											{
												item.label === "Me" && (
													<svg
														viewBox="0 0 24 24"
														aria-hidden="true"
														class="h-4 w-4 fill-none stroke-current"
														stroke-width="1.8"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<circle cx="12" cy="8.25" r="3"></circle>
														<path d="M6.75 18.75a5.25 5.25 0 0 1 10.5 0"></path>
													</svg>
												)
											}
										</span>
										<span>{item.label}</span>
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</div>
		</main>
	</body>
</html>

<style>
	.hero-photo-shell {
		position: relative;
		width: min(62vw, 18rem);
		--photo-focus-x: 52%;
		--photo-focus-y: 40%;
		display: flex;
		align-items: center;
		justify-content: center;
		isolation: isolate;
	}

	.hero-photo-glow {
		position: absolute;
		inset: 8% 6% 8%;
		background:
			radial-gradient(circle at var(--photo-focus-x) var(--photo-focus-y), rgba(255, 166, 89, 0.88) 0%, rgba(255, 166, 89, 0.42) 20%, rgba(255, 166, 89, 0) 56%),
			radial-gradient(circle at calc(var(--photo-focus-x) + 8%) calc(var(--photo-focus-y) - 6%), rgba(255, 240, 221, 0.44) 0%, rgba(255, 240, 221, 0) 30%);
		filter: blur(46px);
		z-index: -2;
	}

	.hero-photo-blend {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse at var(--photo-focus-x) var(--photo-focus-y), rgba(255, 176, 96, 0.34) 0%, rgba(255, 176, 96, 0.16) 24%, rgba(255, 176, 96, 0) 56%),
			linear-gradient(90deg, rgba(18, 17, 24, 0.90) 0%, rgba(18, 17, 24, 0.40) 18%, rgba(18, 17, 24, 0.06) 38%, rgba(18, 17, 24, 0) 56%),
			linear-gradient(180deg, rgba(18, 17, 24, 0) 0%, rgba(18, 17, 24, 0) 58%, rgba(18, 17, 24, 0.28) 80%, rgba(18, 17, 24, 0.82) 100%);
		mix-blend-mode: screen;
		opacity: 0.92;
		z-index: 1;
	}

	.hero-photo-image {
		position: relative;
		z-index: 0;
		display: block;
		width: 100%;
		height: auto;
		object-fit: contain;
		object-position: center bottom;
		filter: drop-shadow(0 30px 90px rgba(0, 0, 0, 0.72));
		-webkit-mask-image: radial-gradient(
			ellipse 68% 74% at var(--photo-focus-x) calc(var(--photo-focus-y) + 4%),
			rgba(0, 0, 0, 1) 0%,
			rgba(0, 0, 0, 1) 40%,
			rgba(0, 0, 0, 0.96) 56%,
			rgba(0, 0, 0, 0.7) 70%,
			rgba(0, 0, 0, 0.24) 84%,
			transparent 96%
		);
		mask-image: radial-gradient(
			ellipse 68% 74% at var(--photo-focus-x) calc(var(--photo-focus-y) + 4%),
			rgba(0, 0, 0, 1) 0%,
			rgba(0, 0, 0, 1) 40%,
			rgba(0, 0, 0, 0.96) 56%,
			rgba(0, 0, 0, 0.7) 70%,
			rgba(0, 0, 0, 0.24) 84%,
			transparent 96%
		);
	}

	@media (min-width: 640px) {
		.hero-photo-shell {
			width: min(42vw, 20rem);
		}
	}

	@media (min-width: 1024px) {
		.hero-photo-shell {
			width: min(26vw, 24rem);
		}
	}

	@media (min-width: 1280px) {
		.hero-photo-shell {
			width: min(24vw, 25rem);
		}
	}
</style>
