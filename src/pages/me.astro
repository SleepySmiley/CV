---
import "../styles/global.css";
import CursorLight from "../components/CursorLight.astro";
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Me | CV Hub</title>
	</head>
	<body class="min-h-screen bg-stone-950 px-6 py-12 text-stone-100">
		<main class="relative mx-auto flex min-h-[80vh] max-w-4xl flex-col items-start justify-center overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur">
			<CursorLight />
			<p class="text-sm uppercase tracking-[0.3em] text-stone-500">04 / Me</p>
			<h1 class="mt-4 text-4xl font-semibold text-white">Me</h1>
			<p class="mt-4 max-w-2xl text-base leading-8 text-stone-300">
				Questa sezione arrivera dopo. Per ora la HUB page e pronta e questo link e gia funzionante.
			</p>
			<a href="/" class="mt-8 rounded-full border border-white/10 px-5 py-3 text-sm text-stone-200 transition hover:border-amber-200/40 hover:text-white">
				Torna alla HUB
			</a>
		</main>
	</body>
</html>
