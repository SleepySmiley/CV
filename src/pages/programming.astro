---
import "../styles/global.css";
import CursorLight from "../components/CursorLight.astro";

const navigation = [
	{ href: "/", label: "Home", current: false },
	{ href: "/programming", label: "Programming", current: true },
	{ href: "/beatmaking", label: "Beatmaking", current: false },
	{ href: "/photography", label: "Photography", current: false },
	{ href: "/me", label: "Me", current: false },
];

const strengths = [
	"Sviluppo principalmente in C# con focus su app Windows oriented",
	"Ho ampliato il mio percorso anche sul web frontend",
	"Mi interessa unire logica, chiarezza e una buona presentazione visiva",
	"Prediligo progetti concreti, utili e facili da usare",
];

const languageUsage = [
	{ name: "C#", value: 55 },
	{ name: "CSS", value: 25 },
	{ name: "Ts/Js", value: 15 },
	{ name: "Python", value: 5 },
];

const projects = [
	{
		index: "01",
		title: "CV Web Project",
		status: "Core focus",
		repo: "https://github.com/SleepySmiley/CV",
		description:
			"Sito ideato come CV suddiviso in varie pagine per i miei ambiti lavorativi. Creato attraverso Astro framework e TailWind per facilitare l'utilizzo dell'IA",
		details: ["Astro", "TailWind", "Web", "Frontend"],
	},
	{
		index: "02",
		title: "InTime",
		status: "On Going",
		repo: "https://github.com/SleepySmiley/InTime",
		description:
			"Un programma ideato per gestire i tempi delle diverse parti di una riunione. Creato su base WPF con C# e Xaml",
		details: ["C#", "Xaml", "Utility", "Tool"],
	},
	{
		index: "03",
		title: "Stem Separator",
		status: "Endend",
		repo: "https://github.com/SleepySmiley/Stem-Separator",
		description:
			"Un piccolo tool ideato su Python per la suddivisione degli STEM di una canzone. ",
		details: ["Python", "Tool", "Backend", "Console"],
	},
];

const contacts = [
	{ label: "Email", value: "christianmattiolo@gmail.com", href: "mailto:christianmattiolo@gmail.com" },
	{ label: "Telefono", value: "+39 392 365 1045", href: "tel:+393923651045" },
	{ label: "GitHub", value: "github.com/SleepySmiley", href: "https://github.com/SleepySmiley" },
	{ label: "Base", value: "Mercato Saraceno, IT", href: "https://maps.google.com/?q=Mercato-Saraceno,Italy" },
];
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="Programming page di Christian Mattiolo: C#, app Windows oriented, frontend recente, progetti e contatti."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<title>Christian Mattiolo | Programming</title>
	</head>
	<body class="min-h-screen bg-[#0f0d14] text-stone-100">
		<main class="relative isolate overflow-hidden pb-36">
			<div class="absolute inset-0 -z-30 bg-[linear-gradient(130deg,#0f0d14_0%,#15131b_38%,#2a221f_70%,#0f0d14_100%)]"></div>
			<div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_82%_18%,rgba(255,150,70,0.28),rgba(255,150,70,0.0)_28%),radial-gradient(circle_at_18%_72%,rgba(125,211,252,0.12),rgba(125,211,252,0.0)_24%)]"></div>
			<div class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.025)_1px,transparent_1px)] bg-size-[80px_80px] opacity-20"></div>
			<CursorLight />

			<div class="mx-auto flex min-h-screen w-full max-w-7xl flex-col px-6 py-6 sm:px-10 sm:py-8 lg:px-14 lg:py-10">
				<header class="flex items-center justify-start">
					<a
						href="/"
						class="inline-flex items-center gap-3 text-sm font-medium text-white/90"
						style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
					>
						<span class="h-2.5 w-2.5 rounded-full bg-amber-300 shadow-[0_0_18px_rgba(252,211,77,0.9)]"></span>
						<span>Christian Mattiolo / Programming</span>
					</a>
				</header>

				<section class="grid flex-1 gap-10 py-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.72fr)] lg:items-center lg:gap-12 lg:py-12">
					<div class="max-w-3xl">
						<p
							class="text-sm font-semibold uppercase tracking-[0.22em] text-amber-300"
							style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
						>
							01 / Programming
						</p>
						<h1
							class="mt-5 text-5xl font-bold leading-[0.94] tracking-tight text-white sm:text-6xl xl:text-[5.25rem]"
							style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
						>
							BackEnd and FrontEnd Developer
						</h1>
						<p class="mt-6 max-w-2xl text-base leading-8 text-stone-300 sm:text-lg">
							Programmare è la mia passione, ho un ottima capacità di FastLearning e un buon problem solving.
							Mi piacciono le sfide complesse che mi mettono in gioco e imparare sempre qualcosa di nuovo, infatti 
							questa è solo una delle mie passioni.
						</p>

						<div class="mt-8 flex flex-wrap gap-3">
							<a
								href="mailto:christianmattiolo@gmail.com"
								class="rounded-full bg-amber-400 px-5 py-3 text-sm font-semibold text-stone-950 shadow-[0_12px_32px_rgba(255,184,0,0.24)] transition hover:-translate-y-0.5 hover:bg-amber-300"
								style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
							>
								Contattami
							</a>
							<a
								href="https://github.com/SleepySmiley"
								target="_blank"
								rel="noreferrer"
								class="rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-medium text-stone-100 transition hover:border-white/20 hover:bg-white/10"
								style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
							>
								GitHub / SleepySmiley
							</a>
						</div>
					</div>

					<div class="grid gap-4 rounded-4xl border border-white/10 bg-white/6 p-6 shadow-[0_18px_70px_rgba(0,0,0,0.28)] backdrop-blur-xl">
						<div class="grid gap-2">
							<p
								class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
								style="font-family: 'IBM Plex Mono', monospace;"
							>
								Quick Profile
							</p>
							<p class="text-2xl font-semibold text-white" style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;">
								Christian Mattiolo
							</p>
							<p class="text-sm leading-7 text-stone-300">
								Sono uno sviluppatore di base C# con svariati interessi su progettazione Web,
								creazione di gestionali e applicazioni di ogni genere.
							</p>
						</div>

						<div class="grid gap-3 border-t border-white/10 pt-4 text-sm text-stone-300">
							<div class="flex items-center justify-between gap-4">
								<span class="text-stone-500">Main focus</span>
								<span>C# / Windows</span>
							</div>
							<div class="flex items-center justify-between gap-4">
								<span class="text-stone-500">Secondary focus</span>
								<span>Web frontend</span>
							</div>
							<div class="flex items-center justify-between gap-4">
								<span class="text-stone-500">Location</span>
								<span>Mercato Saraceno, IT</span>
							</div>
						</div>

						<div class="border-t border-white/10 pt-4">
							<p
								class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
								style="font-family: 'IBM Plex Mono', monospace;"
							>
								Strengths
							</p>
							<ul class="mt-4 grid gap-3">
								{
									strengths.map((item) => (
										<li class="flex items-start gap-3 text-sm leading-6 text-stone-200">
											<span class="mt-2 h-1.5 w-1.5 rounded-full bg-amber-300"></span>
											<span>{item}</span>
										</li>
									))
								}
							</ul>
						</div>
					</div>
				</section>

				<section class="grid gap-6 border-t border-white/10 py-10 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)]">
					<div>
						<p
							class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
							style="font-family: 'IBM Plex Mono', monospace;"
						>
							Languages
						</p>
						<h2
							class="mt-3 text-3xl font-semibold text-white"
							style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
						>
							Linguaggi e utilizzo
						</h2>
					</div>

					<div class="grid gap-4">
						{
							languageUsage.map((item) => (
								<div class="rounded-[1.6rem] border border-white/10 bg-white/5 p-5">
									<div class="flex items-center justify-between gap-4">
										<div>
											<p class="text-base font-medium text-white">{item.name}</p>
											<p class="mt-1 text-xs uppercase tracking-[0.18em] text-stone-500">
											</p>
										</div>
										<span class="text-sm font-semibold text-amber-200">{item.value}%</span>
									</div>
									<div class="mt-4 h-2 rounded-full bg-white/8">
										<div
											class="h-full rounded-full bg-[linear-gradient(90deg,rgba(252,211,77,0.95),rgba(249,115,22,0.85))]"
											style={`width: ${item.value}%`}
										></div>
									</div>
								</div>
							))
						}
					</div>
				</section>

				<section class="py-4">
					<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
						<div>
							<p
								class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
								style="font-family: 'IBM Plex Mono', monospace;"
							>
								Projects
							</p>
							<h2
								class="mt-3 text-3xl font-semibold text-white"
								style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
							>
								Progetti e direzioni su cui sto lavorando
							</h2>
						</div>

					</div>

					<div class="mt-8 grid gap-5 xl:grid-cols-3">
						{
							projects.map((project) => (
								<article class="flex h-full flex-col rounded-[1.8rem] border border-white/10 bg-white/5 p-6 shadow-[0_18px_70px_rgba(0,0,0,0.2)] backdrop-blur">
									<div class="flex items-start justify-between gap-4">
										<p
											class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
											style="font-family: 'IBM Plex Mono', monospace;"
										>
											{project.index}
										</p>
										<span class="rounded-full border border-amber-300/20 bg-amber-300/10 px-3 py-1 text-[0.72rem] text-amber-200">
											{project.status}
										</span>
									</div>

									<h3
										class="mt-5 text-2xl font-semibold text-white"
										style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
									>
										{project.title}
									</h3>
									<p class="mt-4 flex-1 text-sm leading-7 text-stone-300">{project.description}</p>

									<ul class="mt-6 flex flex-wrap gap-2">
										{
											project.details.map((detail) => (
												<li class="rounded-full border border-white/10 bg-black/20 px-3 py-1.5 text-xs text-stone-300">
													{detail}
												</li>
											))
										}
									</ul>

									<a
										href={project.repo}
										target="_blank"
										rel="noreferrer"
										class="mt-6 inline-flex w-fit items-center gap-2 rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm font-medium text-white transition hover:border-amber-200/30 hover:bg-white/10"
										style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
									>
										<span>Repository</span>
										<svg
											viewBox="0 0 24 24"
											aria-hidden="true"
											class="h-4 w-4 fill-none stroke-current"
											stroke-width="1.8"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<path d="M7.5 16.5 16.5 7.5"></path>
											<path d="M9 7.5h7.5V15"></path>
										</svg>
									</a>
								</article>
							))
						}
					</div>
				</section>

				<section class="mt-auto border-t border-white/10 py-10">
					<div class="grid gap-6 lg:grid-cols-[minmax(0,0.78fr)_minmax(0,1.22fr)]">
						<div>
							<p
								class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
								style="font-family: 'IBM Plex Mono', monospace;"
							>
								Contacts
							</p>
							<h2
								class="mt-3 text-3xl font-semibold text-white"
								style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
							>
								Contatti
							</h2>
							<p class="mt-4 max-w-xl text-base leading-8 text-stone-300">
								Se vuole contattarmi per un ruolo, una collaborazione o semplicemente per vedere piu
								da vicino quello che sto costruendo, qui trovi i riferimenti principali.
							</p>
						</div>

						<div class="grid gap-4">
							{
								contacts.map((item) => (
									<a
										href={item.href}
										target={item.href.startsWith("http") ? "_blank" : undefined}
										rel={item.href.startsWith("http") ? "noreferrer" : undefined}
										class="flex items-center justify-between gap-4 rounded-[1.4rem] border border-white/10 bg-white/5 px-5 py-4 text-sm text-stone-200 transition hover:border-white/20 hover:bg-white/8"
									>
										<span class="text-stone-500">{item.label}</span>
										<span class="text-right text-white">{item.value}</span>
									</a>
								))
							}
						</div>
					</div>
				</section>
			</div>

			<nav aria-label="Main sections" class="fixed inset-x-0 bottom-4 z-30 px-4 sm:px-6">
				<ul class="mx-auto flex w-full max-w-5xl flex-wrap items-center justify-center gap-3 rounded-4xl border border-white/10 bg-[rgba(75,63,59,0.78)] px-4 py-4 shadow-[0_18px_60px_rgba(0,0,0,0.35)] backdrop-blur-xl sm:flex-nowrap sm:gap-2 sm:px-3">
					{
						navigation.map((item) => (
							<li class="w-full sm:w-auto sm:flex-1">
								<a
									href={item.href}
									aria-current={item.current ? "page" : undefined}
									class:list={[
										"flex items-center justify-center gap-3 rounded-full px-4 py-3 text-sm font-medium transition duration-300",
										item.current
											? "bg-white text-stone-900 shadow-[0_8px_24px_rgba(255,255,255,0.22)]"
											: "text-white/92 hover:bg-white/10",
									]}
									style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
								>
									<span class={item.current ? "text-stone-700" : "text-white/80"}>
										{
											item.label === "Home" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M3.75 10.5 12 4.5l8.25 6"></path>
													<path d="M6 9.75v9h12v-9"></path>
												</svg>
											)
										}
										{
											item.label === "Programming" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<rect x="4.5" y="5.25" width="15" height="13.5" rx="2"></rect>
													<path d="m9 10.25-2 1.75 2 1.75"></path>
													<path d="m15 10.25 2 1.75-2 1.75"></path>
												</svg>
											)
										}
										{
											item.label === "Beatmaking" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M7.5 18V8.25"></path>
													<path d="M12 18V5.25"></path>
													<path d="M16.5 18v-7.5"></path>
												</svg>
											)
										}
										{
											item.label === "Photography" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M4.5 8.25h4l1.5-2.25h4l1.5 2.25h4v9.75a2.25 2.25 0 0 1-2.25 2.25h-11A2.25 2.25 0 0 1 4.5 18V8.25Z"></path>
													<circle cx="12" cy="13.5" r="3"></circle>
												</svg>
											)
										}
										{
											item.label === "Me" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<circle cx="12" cy="8.25" r="3"></circle>
													<path d="M6.75 18.75a5.25 5.25 0 0 1 10.5 0"></path>
												</svg>
											)
										}
									</span>
									<span>{item.label}</span>
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</main>
	</body>
</html>
