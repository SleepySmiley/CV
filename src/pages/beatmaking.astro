---
import "../styles/global.css";
import CursorLight from "../components/CursorLight.astro";

const navigation = [
	{ href: "/", label: "Home", current: false },
	{ href: "/programming", label: "Programming", current: false },
	{ href: "/beatmaking", label: "Beatmaking", current: true },
	{ href: "/photography", label: "Photography", current: false },
	{ href: "/me", label: "Me", current: false },
];

const equalizerBars = [42, 74, 56, 92, 64, 108, 72, 98, 58, 88, 46, 80, 62, 102, 70, 90];

const capacities = [
	"Mixing e sound design per dare personalità al brano",
	"Ricerca di suoni precisi e coerenti con l'identità del pezzo",
	"Costruzione di ritmica, bounce e dinamica senza perdere pulizia",
	"Arrangiamento progressivo per dare movimento e identità al brano",
	"Attenzione al mastering e alla rifinitura finale per un risultato professionale",
];

const projects = [
	{
		index: "01",
		title: "Chill Trap Beat",
		status: "Trap",
		audioUrl: "/audio/beat-01.mp3",
		audioLabel: "Beat 01 preview",
		description:
			"Una base musicale prodotta in FL Studio, con focus su sonorita trap ma con pochi elementi e ordinati.\nQuesto infatti segue un ritmo lento ma incalzante.",
		details: ["Chill", "Trap", "Moody", "Atmospheric"],
	},
	{
		index: "02",
		title: "Hip Hop Beat",
		status: "Hip Hop",
		audioUrl: "/audio/beat-02.mp3",
		audioLabel: "Beat 02 preview",
		description:
			"Una base musicale prodotta in FL Studio, con focus su sonorita rap con una varieta di batteria che gira intorno ad una semplice melodia.\nQuesto beat ha la caratteristica di avere un basso molto profondo e pieno",
		details: ["Hip Hop", "Bass", "Creepy", "Groovy"],
	},
	{
		index: "03",
		title: "Jerky Experimental Beat",
		status: "Jerky",
		audioUrl: "/audio/beat-03.mp3",
		audioLabel: "Beat 03 preview",
		description:
			"Una base musicale prodotta in FL Studio, con focus su sonorita trap e approccio sperimentale.\nQuesto progetto in particolare segue una direzione jerky.",
		details: ["Jerky", "Experimental", "Edit", "Unconventional"],
	},
];

const contacts = [
	{ label: "Email", value: "christianmattiolo@gmail.com", href: "mailto:christianmattiolo@gmail.com" },
	{ label: "Telefono", value: "+39 392 365 1045", href: "tel:+393923651045" },
	{ label: "GitHub", value: "github.com/SleepySmiley", href: "https://github.com/SleepySmiley" },
	{ label: "Base", value: "Mercato Saraceno, IT", href: "https://maps.google.com/?q=Mercato-Saraceno,Italy" },
];
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="Beatmaking page di Christian Mattiolo: produzione, FL Studio, capacita, progetti e contatti."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<title>Christian Mattiolo | Beatmaking</title>
	</head>
	<body class="min-h-screen bg-[#0e0b12] text-stone-100">
		<main class="relative isolate overflow-hidden pb-36">
			<div class="absolute inset-0 -z-30 bg-[linear-gradient(140deg,#0e0b12_0%,#15111b_34%,#21161d_62%,#0e0b12_100%)]"></div>
			<div class="absolute inset-0 -z-20 bg-[radial-gradient(circle_at_74%_18%,rgba(255,128,54,0.30),rgba(255,128,54,0.0)_28%),radial-gradient(circle_at_20%_78%,rgba(236,72,153,0.14),rgba(236,72,153,0.0)_24%),radial-gradient(circle_at_58%_34%,rgba(251,191,36,0.14),rgba(251,191,36,0.0)_18%),radial-gradient(circle_at_88%_54%,rgba(249,115,22,0.12),rgba(249,115,22,0.0)_20%),radial-gradient(circle_at_12%_24%,rgba(244,114,182,0.10),rgba(244,114,182,0.0)_18%)]"></div>
			<div class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-size-[84px_84px] opacity-15"></div>
			<div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_64%_20%,rgba(255,244,214,0.12),rgba(255,244,214,0.0)_12%),radial-gradient(circle_at_30%_60%,rgba(255,160,122,0.08),rgba(255,160,122,0.0)_14%),radial-gradient(circle_at_82%_72%,rgba(253,186,116,0.08),rgba(253,186,116,0.0)_16%)] blur-2xl"></div>
			<CursorLight />

			<div class="pointer-events-none absolute inset-x-0 bottom-24 z-0 hidden h-56 items-end gap-3 px-10 opacity-30 lg:flex">
				{
					equalizerBars.map((height, index) => (
						<span
							class="beat-bar"
							style={`height:${height}px; animation-delay:${index * 0.14}s;`}
						></span>
					))
				}
			</div>

			<div class="mx-auto flex min-h-screen w-full max-w-7xl flex-col px-6 py-6 sm:px-10 sm:py-8 lg:px-14 lg:py-10">
				<header class="flex items-center justify-start">
					<a
						href="/"
						class="inline-flex items-center gap-3 text-sm font-medium text-white/90"
						style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
					>
						<span class="h-2.5 w-2.5 rounded-full bg-orange-300 shadow-[0_0_18px_rgba(253,186,116,0.95)]"></span>
						<span>Christian Mattiolo / Beatmaking</span>
					</a>
				</header>

				<section class="grid flex-1 gap-10 py-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.72fr)] lg:items-center lg:gap-12 lg:py-12">
					<div class="max-w-3xl">
						<p
							class="text-sm font-semibold uppercase tracking-[0.22em] text-orange-300"
							style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
						>
							02 / Beatmaking
						</p>
						<h1
							class="mt-5 text-5xl font-bold leading-[0.94] tracking-tight text-white sm:text-6xl xl:text-[5.25rem]"
							style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
						>
							Beatmaker
							<span class="block text-stone-300">and Music Producer</span>
						</h1>
						<p class="mt-6 max-w-2xl text-base leading-8 text-stone-300 sm:text-lg">
							Il beatmaking e la produzione musicale sono il cuore della mia espressione creativa, dove posso spaziare tra suoni, ritmi che rispecchiano la mia persona. L'ambito che piu mi appasiona è sicuramente la batteria che da bounce, dinamicità e personalità.
						</p>

						<div class="mt-8 flex flex-wrap gap-3">
							<a
								href="mailto:christianmattiolo@gmail.com"
								class="rounded-full bg-orange-400 px-5 py-3 text-sm font-semibold text-stone-950 shadow-[0_12px_32px_rgba(249,115,22,0.28)] transition hover:-translate-y-0.5 hover:bg-orange-300"
								style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
							>
								Contattami
							</a>
						</div>
					</div>

					<div class="grid gap-4 rounded-4xl border border-white/10 bg-white/6 p-6 shadow-[0_18px_70px_rgba(0,0,0,0.28)] backdrop-blur-xl">
						<div class="grid gap-2">
							<p
								class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
								style="font-family: 'IBM Plex Mono', monospace;"
							>
								Quick Profile
							</p>
							<p class="text-2xl font-semibold text-white" style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;">
								Christian Mattiolo
							</p>
							<p class="text-sm leading-7 text-stone-300">
								Produco beat e idee sonore con un approccio attento al groove e la scelta sonora di un brano.
							</p>
						</div>

						<div class="grid gap-3 border-t border-white/10 pt-4 text-sm text-stone-300">
							<div class="flex items-center justify-between gap-4">
								<span class="text-stone-500">Main software</span>
								<span>FL Studio</span>
							</div>
							<div class="flex items-center justify-between gap-4">
								<span class="text-stone-500">Focus</span>
								<span>Beatmaking / Production</span>
							</div>
							<div class="flex items-center justify-between gap-4">
								<span class="text-stone-500">Location</span>
								<span>Mercato Saraceno, IT</span>
							</div>
						</div>

						<div class="border-t border-white/10 pt-4">
							<p
								class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
								style="font-family: 'IBM Plex Mono', monospace;"
							>
								Direction
							</p>
							<p class="mt-4 text-sm leading-7 text-stone-200">
								Mi interessa costruire produzioni che siano riconoscibili personali e uniche, partendo dalla melodia fino all'arrangiamento completo.
							</p>
						</div>
					</div>
				</section>

				<section class="grid gap-6 border-t border-white/10 py-10 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)]">
					<div>
						<p
							class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
							style="font-family: 'IBM Plex Mono', monospace;"
						>
							Software
						</p>
						<h2
							class="mt-3 text-3xl font-semibold text-white"
							style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
						>
							FL Studio
						</h2>
					</div>

					<div class="rounded-4xl border border-white/10 bg-white/5 p-6 shadow-[0_18px_70px_rgba(0,0,0,0.18)] backdrop-blur">
						<div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center">
							<div class="flex h-28 w-28 items-center justify-center rounded-[1.8rem] border border-orange-200/10 bg-[radial-gradient(circle_at_center,rgba(251,146,60,0.22),rgba(249,115,22,0.10)_52%,rgba(249,115,22,0.04)_72%,rgba(249,115,22,0.0)_100%)] p-3 shadow-[0_0_40px_rgba(249,115,22,0.16)]">
								<img
									src="/logos/FLStudio-logo.png"
									alt="FL Studio logo"
									class="h-full w-full object-contain drop-shadow-[0_8px_24px_rgba(0,0,0,0.28)]"
								/>
							</div>

							<div class="max-w-2xl">
								<p
									class="text-[0.72rem] uppercase tracking-[0.22em] text-orange-300"
									style="font-family: 'IBM Plex Mono', monospace;"
								>
									Main DAW
								</p>
								<p class="mt-3 text-2xl font-semibold text-white" style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;">
									FL Studio
								</p>
								<p class="mt-3 text-sm leading-7 text-stone-300">
									Il software principale con cui costruisco beat, arrangiamenti e idee sonore. E il
									centro della mia produzione, dal primo loop fino alla rifinitura finale del pezzo.
								</p>
							</div>
						</div>
					</div>
				</section>

				<section class="grid gap-6 border-t border-white/10 py-10 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)]">
					<div>
						<p
							class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
							style="font-family: 'IBM Plex Mono', monospace;"
						>
							Capacita
						</p>
						<h2
							class="mt-3 text-3xl font-semibold text-white"
							style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
						>
							Capacita sviluppate
						</h2>
					</div>

					<div class="grid gap-4">
						{
							capacities.map((item, index) => (
								<div class="rounded-[1.6rem] border border-white/10 bg-white/5 p-5">
									<div class="flex items-start gap-4">
										<span class="rounded-full border border-white/10 bg-black/20 px-3 py-1 text-xs text-stone-300">
											0{index + 1}
										</span>
										<p class="text-sm leading-7 text-stone-200">{item}</p>
									</div>
								</div>
							))
						}
					</div>
				</section>

				<section class="py-4">
					<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
						<div>
							<p
								class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
								style="font-family: 'IBM Plex Mono', monospace;"
							>
								Projects
							</p>
							<h2
								class="mt-3 text-3xl font-semibold text-white"
								style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
							>
								Progetti e direzioni
							</h2>
						</div>
					</div>

					<div class="mt-8 grid gap-5 xl:grid-cols-3">
						{
							projects.map((project) => (
								<article class="flex h-full flex-col rounded-[1.8rem] border border-white/10 bg-white/5 p-6 shadow-[0_18px_70px_rgba(0,0,0,0.2)] backdrop-blur">
									<div class="flex items-start justify-between gap-4">
										<p
											class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
											style="font-family: 'IBM Plex Mono', monospace;"
										>
											{project.index}
										</p>
										<span class="rounded-full border border-orange-300/20 bg-orange-300/10 px-3 py-1 text-[0.72rem] text-orange-200">
											{project.status}
										</span>
									</div>

									<h3
										class="mt-5 text-2xl font-semibold text-white"
										style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
									>
										{project.title}
									</h3>
									<p class="mt-4 flex-1 text-sm leading-7 text-stone-300">{project.description}</p>

									<ul class="mt-6 flex flex-wrap gap-2">
										{
											project.details.map((detail) => (
												<li class="rounded-full border border-white/10 bg-black/20 px-3 py-1.5 text-xs text-stone-300">
													{detail}
												</li>
											))
										}
									</ul>

									<div class="mt-6 rounded-[1.3rem] border border-white/10 bg-black/20 p-4">
										<div class="mb-3 flex items-center justify-between gap-3">
											<p class="text-sm font-medium text-white" style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;">
												{project.audioLabel}
											</p>
											<span class="text-[0.7rem] uppercase tracking-[0.18em] text-stone-500">
												Direct Play
											</span>
										</div>
										<audio controls preload="none" class="beat-audio-player w-full">
											<source src={project.audioUrl} type="audio/mpeg" />
											Il tuo browser non supporta il player audio.
										</audio>
									</div>
								</article>
							))
						}
					</div>
				</section>

				<section class="mt-auto border-t border-white/10 py-10">
					<div class="grid gap-6 lg:grid-cols-[minmax(0,0.78fr)_minmax(0,1.22fr)]">
						<div>
							<p
								class="text-[0.72rem] uppercase tracking-[0.22em] text-stone-500"
								style="font-family: 'IBM Plex Mono', monospace;"
							>
								Contacts
							</p>
							<h2
								class="mt-3 text-3xl font-semibold text-white"
								style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
							>
								Contatti
							</h2>
							<p class="mt-4 max-w-xl text-base leading-8 text-stone-300">
								Se vuoi contattarmi per collaborazioni, produzioni o lavori legati al beatmaking,
								qui trovi i riferimenti principali.
							</p>
						</div>

						<div class="grid gap-4">
							{
								contacts.map((item) => (
									<a
										href={item.href}
										target={item.href.startsWith("http") ? "_blank" : undefined}
										rel={item.href.startsWith("http") ? "noreferrer" : undefined}
										class="flex items-center justify-between gap-4 rounded-[1.4rem] border border-white/10 bg-white/5 px-5 py-4 text-sm text-stone-200 transition hover:border-white/20 hover:bg-white/8"
									>
										<span class="text-stone-500">{item.label}</span>
										<span class="text-right text-white">{item.value}</span>
									</a>
								))
							}
						</div>
					</div>
				</section>
			</div>

			<nav aria-label="Main sections" class="fixed inset-x-0 bottom-4 z-30 px-4 sm:px-6">
				<ul class="mx-auto flex w-full max-w-5xl flex-nowrap items-center justify-start gap-2 overflow-x-auto rounded-4xl border border-white/10 bg-[rgba(75,63,59,0.78)] px-3 py-3 shadow-[0_18px_60px_rgba(0,0,0,0.35)] backdrop-blur-xl sm:justify-center sm:gap-2 sm:overflow-visible sm:px-3 sm:py-4">
					{
						navigation.map((item) => (
							<li class="shrink-0 sm:w-auto sm:flex-1">
								<a
									href={item.href}
									aria-current={item.current ? "page" : undefined}
									class:list={[
										"flex items-center justify-center gap-2 rounded-full px-3 py-2 text-xs font-medium whitespace-nowrap transition duration-300 sm:gap-3 sm:px-4 sm:py-3 sm:text-sm",
										item.current
											? "bg-white text-stone-900 shadow-[0_8px_24px_rgba(255,255,255,0.22)]"
											: "text-white/92 hover:bg-white/10",
									]}
									style="font-family: 'Space Grotesk', 'Segoe UI', sans-serif;"
								>
									<span class={item.current ? "text-stone-700" : "text-white/80"}>
										{
											item.label === "Home" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M3.75 10.5 12 4.5l8.25 6"></path>
													<path d="M6 9.75v9h12v-9"></path>
												</svg>
											)
										}
										{
											item.label === "Programming" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<rect x="4.5" y="5.25" width="15" height="13.5" rx="2"></rect>
													<path d="m9 10.25-2 1.75 2 1.75"></path>
													<path d="m15 10.25 2 1.75-2 1.75"></path>
												</svg>
											)
										}
										{
											item.label === "Beatmaking" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M7.5 18V8.25"></path>
													<path d="M12 18V5.25"></path>
													<path d="M16.5 18v-7.5"></path>
												</svg>
											)
										}
										{
											item.label === "Photography" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M4.5 8.25h4l1.5-2.25h4l1.5 2.25h4v9.75a2.25 2.25 0 0 1-2.25 2.25h-11A2.25 2.25 0 0 1 4.5 18V8.25Z"></path>
													<circle cx="12" cy="13.5" r="3"></circle>
												</svg>
											)
										}
										{
											item.label === "Me" && (
												<svg
													viewBox="0 0 24 24"
													aria-hidden="true"
													class="h-4 w-4 fill-none stroke-current"
													stroke-width="1.8"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<circle cx="12" cy="8.25" r="3"></circle>
													<path d="M6.75 18.75a5.25 5.25 0 0 1 10.5 0"></path>
												</svg>
											)
										}
									</span>
									<span>{item.label}</span>
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</main>
	</body>
</html>

<style>
	.beat-bar {
		flex: 1 1 0;
		min-width: 10px;
		border-radius: 999px 999px 0 0;
		background: linear-gradient(180deg, rgba(253, 186, 116, 0.95), rgba(249, 115, 22, 0.28));
		box-shadow: 0 0 24px rgba(249, 115, 22, 0.2);
		transform-origin: bottom;
		animation: beatPulse 2.6s ease-in-out infinite;
	}

	@keyframes beatPulse {
		0%,
		100% {
			transform: scaleY(0.68);
			opacity: 0.55;
		}

		50% {
			transform: scaleY(1);
			opacity: 1;
		}
	}

	.beat-audio-player {
		height: 42px;
		border-radius: 999px;
		overflow: hidden;
		width: 100%;
		background: rgba(255, 255, 255, 0.08);
		filter: sepia(0.16) hue-rotate(-8deg) saturate(1.12) brightness(1.04);
	}

	.beat-audio-player::-webkit-media-controls-panel {
		background: linear-gradient(135deg, rgba(214, 116, 67, 0.94), rgba(244, 164, 96, 0.94));
	}

	.beat-audio-player::-webkit-media-controls-play-button,
	.beat-audio-player::-webkit-media-controls-mute-button {
		filter: sepia(0.14) saturate(1.15) hue-rotate(-6deg) brightness(1.08);
	}

