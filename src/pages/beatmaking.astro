<script>
	const formatBeatTime = (seconds: number) => {
		if (!Number.isFinite(seconds) || seconds < 0) {
			return "0:00";
		}

		const mins = Math.floor(seconds / 60);
		const secs = Math.floor(seconds % 60)
			.toString()
			.padStart(2, "0");
		return `${mins}:${secs}`;
	};

	const players = Array.from(document.querySelectorAll("[data-audio-player]"));

	players.forEach((player) => {
		const audio = player.querySelector("[data-audio-element]");
		const toggle = player.querySelector("[data-audio-toggle]");
		const seek = player.querySelector("[data-audio-seek]");
		const currentLabel = player.querySelector("[data-audio-current]");
		const durationLabel = player.querySelector("[data-audio-duration]");
		const playIcon = player.querySelector("[data-audio-play-icon]");
		const pauseIcon = player.querySelector("[data-audio-pause-icon]");

		if (!(audio instanceof HTMLAudioElement) || !(seek instanceof HTMLInputElement) || !(toggle instanceof HTMLButtonElement)) {
			return;
		}

		let isScrubbing = false;

		const setProgress = (value: number) => {
			const safeValue = Number.isFinite(value) ? Math.max(0, Math.min(100, value)) : 0;
			seek.value = `${safeValue}`;
			seek.style.setProperty("--beat-progress", `${safeValue}%`);
		};

		const syncIcons = () => {
			const playing = !audio.paused;
			playIcon?.classList.toggle("hidden", playing);
			pauseIcon?.classList.toggle("hidden", !playing);
			toggle.setAttribute("aria-label", playing ? "Metti in pausa il beat" : "Riproduci il beat");
		};

		const syncTime = () => {
			if (!isScrubbing && audio.duration) {
				setProgress((audio.currentTime / audio.duration) * 100);
			}
			if (currentLabel) {
				currentLabel.textContent = formatBeatTime(audio.currentTime);
			}
		};

		const syncDuration = () => {
			if (durationLabel) {
				durationLabel.textContent = formatBeatTime(audio.duration);
			}
		};

		const scrubToValue = () => {
			if (!audio.duration) {
				return;
			}
			audio.currentTime = (Number(seek.value) / 100) * audio.duration;
			syncTime();
		};

		setProgress(0);
		syncIcons();
		syncDuration();
		syncTime();

		toggle.addEventListener("click", () => {
			if (audio.paused) {
				players.forEach((otherPlayer) => {
					const otherAudio = otherPlayer.querySelector("[data-audio-element]");
					if (otherAudio instanceof HTMLAudioElement && otherAudio !== audio) {
						otherAudio.pause();
					}
				});
				void audio.play();
			} else {
				audio.pause();
			}
		});

		audio.addEventListener("play", syncIcons);
		audio.addEventListener("pause", syncIcons);
		audio.addEventListener("loadedmetadata", () => {
			syncDuration();
			syncTime();
		});
		audio.addEventListener("timeupdate", syncTime);
		audio.addEventListener("ended", () => {
			isScrubbing = false;
			setProgress(0);
			syncIcons();
			syncTime();
		});

		seek.addEventListener("input", () => {
			isScrubbing = true;
			setProgress(Number(seek.value));
			scrubToValue();
		});

		seek.addEventListener("change", () => {
			scrubToValue();
			isScrubbing = false;
		});

		seek.addEventListener("pointerup", () => {
			scrubToValue();
			isScrubbing = false;
		});
	});
</script>
